function to-snmp  {
    if [ $# -eq 0 ]; then
        kubectl exec vcmts-m-0 -itc snmp -- bash
    else
        mgmt_ip=$(kubectl exec vcmts-m-0 -itc snmp -- ip a s mgmt | awk '/inet / {print $2}' | cut -d/ -f1)
        echo "$@" | kubectl exec vcmts-m-0 -ic snmp -- snmpwalk -v 2c -c public "$mgmt_ip" "$@"
    fi
}

## Function to execute a given query in a loop and log the output to a file
function psql-query-log() {
    if [ $# -lt 2 ]; then
        echo "Usage: ${FUNCNAME[0]} <output_filename> <query>"
        return
    fi
    local output_file="$1"
    local query
    query=${*:2}
    # handle Ctrl+C
    trap 'echo "Stopping psql logging. Output file: $output_file"; exit' INT

    while true; do
        date >> "$output_file"
        psql-query "$query" >> "$output_file"
        sleep 1
    done
}


########### IPDR related aliases ###########
alias ipdr-logs='kubectl logs vcmts-m-0 -c ipdr --timestamps '


IPDR_LOGGERS_CACHE_FILE="/tmp/ipdr_log_completions"
# Fetches logger names, using a cache to avoid repeated slow kubectl calls.
# This is intended for use by the completion function.
_get_cached_ipdr_loggers() {
    # Cache TTL: 1 day (86400 seconds)
    local cache_ttl=86400

    # Check if cache is valid
    if [ -f "$IPDR_LOGGERS_CACHE_FILE" ] && [ "$(($(date +%s) - $(date +%s -r "$IPDR_LOGGERS_CACHE_FILE")))" -lt "$cache_ttl" ]; then
        cat "$IPDR_LOGGERS_CACHE_FILE"
        return
    fi

    # If cache is invalid or doesn't exist, fetch from kubectl
    # Note: -it flags are omitted for non-interactive scripting.
    local loggers
    loggers=$(kubectl exec vcmts-m-0 -c confd -- nsg-logctl -h localhost:23042 ShowCategory ".*" 2>/dev/null | tail -n +3 | awk '{print $1}')
    
    if [ -n "$loggers" ]; then
        echo "$loggers" > "$IPDR_LOGGERS_CACHE_FILE"
        echo "$loggers"
    fi
}

# Bash completion function for the ipdr-log command.
_ipdr_log_completions() {
    local cur_word prev_word
    cur_word="${COMP_WORDS[COMP_CWORD]}"
    prev_word="${COMP_WORDS[COMP_CWORD-1]}"
    
    local log_levels="debug info trace warn error"

    # Completion for the main command (get|set)
    if [[ ${COMP_CWORD} -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "get set" -- "${cur_word}") )
        return 0
    fi

    local command="${COMP_WORDS[1]}"
    case "$command" in
        get)
            # Completion for 'get' is the list of loggers
            if [[ ${COMP_CWORD} -eq 2 ]]; then
                local loggers
                loggers=$(_get_cached_ipdr_loggers)
                COMPREPLY=( $(compgen -W "${loggers}" -- "${cur_word}") )
            fi
            ;;
        set)
            # Completion for 'set' can be a logger or a log level
            if [[ ${COMP_CWORD} -eq 2 ]]; then
                local loggers
                loggers=$(_get_cached_ipdr_loggers)
                COMPREPLY=( $(compgen -W "${loggers} ${log_levels}" -- "${cur_word}") )
            # If the previous word was a logger, complete with log levels.
            # If the previous word was a log level, no more completions.
            elif [[ ${COMP_CWORD} -eq 3 ]]; then
                if [[ " ${log_levels} " =~ " ${prev_word} " ]]; then
                    COMPREPLY=()
                else
                    COMPREPLY=( $(compgen -W "${log_levels}" -- "${cur_word}") )
                fi
            fi
            ;;
    esac
}

_ipdr_log_usage() {
    echo "Usage: ipdr-log <command> [options]"
    echo ""
    echo "A bash tool to interact with IPDR loggers."
    echo ""
    echo "Commands:"
    echo "  get [logger_name]   Get log level for a specific logger or all loggers."
    echo "  set <options>       Set log level for a logger."
    echo ""
    echo "Options for 'set':"
    echo "  <logger_name> <log_level>  Set a specific logger to a specific level."
    echo "  <log_level>                Set all loggers ('.*') to a specific level."
    echo "  <logger_name>              Set a specific logger to the default 'info' level."
    echo ""
    echo "Supported log levels: debug, info, trace, warn, error"
    echo ""
    echo "Bash completion is available for commands, loggers, and log levels."
}

# The main ipdr-log function.
ipdr-log() {
    if [[ $# -eq 0 ]]; then
        _ipdr_log_usage
        return 1
    fi

    local option="$1"
    shift

    case "$option" in
        get)
            local logger_name="${1:-.*}"
            
            # Execute the command and store the output
            local output
            output=$(kubectl exec vcmts-m-0 -itc confd -- nsg-logctl -h localhost:23042 ShowCategory "$logger_name")
            
            # Print the output for the user
            echo "$output"

            # If we fetched all loggers, update the cache for completion
            if [ "$logger_name" = ".*" ]; then
                echo "$output" | tail -n +3 | awk '{print $1}' > "$IPDR_LOGGERS_CACHE_FILE"
            fi
            ;;
        set)
            local logger_name=".*"
            local log_level="info"
            local log_levels="debug info trace warn error"

            if [[ $# -eq 1 ]]; then
                if [[ " $log_levels " =~ " $1 " ]]; then
                    log_level="$1"
                else
                    logger_name="$1"
                fi
            elif [[ $# -gt 1 ]]; then
                logger_name="$1"
                log_level="$2"
            fi

            if [[ ! " $log_levels " =~ " $log_level " ]]; then
                echo "Error: Invalid log level '$log_level'." >&2
                echo "Supported levels are: $log_levels" >&2
                return 1
            fi
            
            # Note: -it flags are omitted for non-interactive scripting.
            kubectl exec vcmts-m-0 -c confd -- nsg-logctl -h localhost:23042 SetCategoryPriority "$logger_name" "$log_level"
            ;;
        *)
            _ipdr_log_usage
            return 1
            ;;
    esac
}

# Register the completion function for the ipdr-log command.
complete -F _ipdr_log_completions ipdr-log


# Iterate over all pods and containers and search for a given string in the logs
# If the optional flag -s or --save is passed, the logs that match the search string will be saved to files
function search_all_k8s_logs() {
    if [ $# -lt 1 ] || [ $# -gt 2 ]; then
        echo "Usage: search_all_k8s_logs <search-string> [-s|--save]"
        return 1
    fi

    search_string="$1"
    save_logs=false

    if [ "$2" = "-s" ] || [ "$2" = "--save" ]; then
        save_logs=true
    fi

    echo "Searching for: $search_string"
    echo "-----------------------------------"

    kubectl get pods --all-namespaces -o jsonpath='{range .items[*]}{.metadata.namespace} {.metadata.name}{"\n"}' | while read -r namespace pod; do
        echo "Namespace: $namespace, Pod: $pod"
        containers=$(kubectl get pod "$pod" -n "$namespace" -o jsonpath='{.spec.containers[*].name}')
        for container in $containers; do
            echo "  Container: $container"
            if $save_logs; then
                if kubectl logs "$pod" -n "$namespace" -c "$container" 2>/dev/null | $(which grep) -q -i "$search_string"; then
                    log_file="${namespace}_${pod}_${container}.log"
                    echo "    Match found. Saving log to $log_file"
                    kubectl logs "$pod" -n "$namespace" -c "$container" > "$log_file"
                else
                    echo "    No matches found"
                fi
            else
                kubectl logs "$pod" -n "$namespace" -c "$container" 2>/dev/null | $(which grep) -i "$search_string" || echo "    No matches found"
            fi
        done
        echo "-----------------------------------"
    done
}



# Start an interactive bash session inside mulpi container. Pod number is passed with argument.
function to-mulpi() {
    if [ -z "$1" ]; then
        # Get the active pod name
        first_cluter_status=$(echo "show cluster status" | kubectl exec vcmts-m-0 -ic confd -- su admin | grep -m1 "CMTS LCCE")
        lcce_num=$(echo "$first_cluter_status" | awk '{print $3}')
        active_pod=$(echo "$first_cluter_status" | awk '{print $6}')
        command="kubectl exec -itc mulpi $active_pod -- bash"
        echo "Entering active pod of LCCE $lcce_num: $active_pod"
    else
        command="kubectl exec $1 -itc mulpi -- bash"
    fi

    echo "Executing $command"
    eval "$command"
}

