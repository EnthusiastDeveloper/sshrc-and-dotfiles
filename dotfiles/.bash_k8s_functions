## Version 3 of the to-psql function
## This function allows to execute psql commands in the postgresql container of the vCMTS
## If no arguments are passed, it starts an interactive psql session.
## If a query is passed, it executes the query and returns the result.
## If the '-w' or '--watch' flag is passed - it executes the query every second and displays the result.
## '-h' or '--help' flag displays the usage information.
function to-psql() {
    if [ $# -eq 0 ]; then
        kubectl exec -it postgresql-0 -c postgresql -- psql odb odb_user
    else
        # if '-w' or '--watch' is passed, start watch-psql
        if [[ "$1" == "-h" || "$1" == "--help" ]]; then
            echo "Usage: ${FUNCNAME[0]} [-w|--watch] <query>"
            echo "If '-w' or '--watch' is passed, the query will be executed repeatedly every second."
            return
        fi
        if [[ "$1" == "-w" || "$1" == "--watch" ]]; then
            shift  # Remove the watch flag
            if [ $# -eq 0 ]; then
                echo "Usage: ${FUNCNAME[0]} --watch <query>"
                return
            fi
            watch -n1 "kubectl exec -i postgresql-0 -c postgresql -- psql odb odb_user -c \"$@\""
        else
            kubectl exec -i postgresql-0 -c postgresql -- psql odb odb_user -c "$@;"
        fi
    fi
}

