ulc-debug() {
  if [ -z "$pod" ]; then
    pod=("$(k get pods -o custom-columns=:metadata.name -lpg --no-headers | head -n1)")
  fi

  args=""

  while (($#)); do
    case $1 in
    -n)
      shift
      namespace=$1
      ;;
    -p)
      shift
      pod=("$1")
      ;;
    -a)
      pod=()
      for p in $(k get pods -o custom-columns=:metadata.name -lpg --no-headers); do
        pod+=("$p")
      done
      shift
      ;;
    *)
      args="$args $1"
      shift
      ;;
    esac
  done

  for p in "${pod[@]}"; do
    echo $p
    kubectl -it exec -n ${namespace:-default} $p -c mulpi -- ulc-debug $args
  done
}

_ulc_debug() {
  latest="${COMP_WORDS[$COMP_CWORD]}"
  #echo ${COMP_WORDS[$COMP_CWORD-1]}
  case "${COMP_WORDS[$COMP_CWORD - 1]}" in
  "-n")
    output=$(kubectl get pods -A -lpg --no-headers | awk '{print $1}' | uniq)
    ;;
  "-p")
    namespace=${namespace:-"default"}
    for i in ${!COMP_WORDS[@]}; do
      if [[ ${COMP_WORDS[$i]} == "-n" ]]; then
        namespace=${COMP_WORDS[$i + 1]}
        break
      fi
    done
    output=$(kubectl get pods -n $namespace -lpg -o custom-columns=NAME:metadata.name --no-headers)
    ;;
  *)
    if [[ -z $pod ]]; then
      pod=$(kubectl get pods -o custom-columns=:metadata.name -lpg --no-headers | head -n1)
    fi
    # rewriting default array which breaks macs because of ':'
    tmp_words=()
    for ((i = 0; i < ${#COMP_WORDS[@]}; i++)); do
      word="${COMP_WORDS[i]}"

      # skip options like -p or --port (and their value)
      if [[ "$word" == -* ]]; then
        COMP_CWORD=$((COMP_CWORD - 2)) # adjust COMP_CWORD accordingly
        ((i++))                        # also skip the value after the option
        continue
      fi

      tmp_words+=("$word")
    done
    COMP_WORDS=("${tmp_words[@]}")

    mapfile -t COMP_WORDS < <(kubectl exec $pod -c mulpi -- /usr/share/ulc-debug/parser ${COMP_WORDS[*]} $COMP_CWORD)
    COMP_CWORD=${COMP_WORDS[-1]}
    unset ${COMP_WORDS[-1]}

    COMPREPLY=$(kubectl exec $pod -c mulpi -- /usr/share/ulc-debug/ulc-debug ${COMP_WORDS[*]})

    if [[ "$COMPREPLY" =~ [A-Za-z]+\(.*\)|.*" ".* ]]; then
      COMPREPLY=("$COMPREPLY" "")
    else
      COMPREPLY=($COMPREPLY)
    fi
    return 0
    ;;
  esac
  COMPREPLY=($(compgen -W "$output" -- $latest))
  unset output

}
complete -o nosort -F _ulc_debug ulc-debug
