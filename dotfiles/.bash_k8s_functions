function to-cli() {
    if [ $# -eq 0 ]; then
        kubectl exec vcmts-m-0 -itc confd -- su admin
    else
        # Run the provided command in the confd container in non-interactive mode
        echo "$@" | kubectl exec vcmts-m-0 -ic confd -- su admin
    fi
}
alias to-lci='to-cli'
alias to-clid='kubectl exec vcmts-m-0 -itc confd -- su debug'

alias scm='to-cli scm'
alias cms='scm'
alias rpds='to-cli scr'
alias clustat='to-cli "show cluster status"'
